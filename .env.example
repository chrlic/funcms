# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Git content store
# Path to the content git repo — must be OUTSIDE the app directory.
# Default: ../funcms-content  (sibling of the funcms/ directory)
# Use an absolute path on servers to avoid ambiguity, e.g. /srv/funcms-content
CONTENT_DIR=../funcms-content
GIT_AUTHOR_NAME=FunCMS
GIT_AUTHOR_EMAIL=cms@localhost
# Optional: push content to a remote repo on every write
# GIT_REMOTE=origin

# Default admin credentials (only used on first run to seed admin user)
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=changeme123

# App
APP_NAME=FunCMS
NODE_ENV=development
